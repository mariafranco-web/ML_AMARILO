config {
  type: "table",
  schema: "WKS_COTIZACIONES_ML",
  name: "03_Obt_Cotizaciones_split",
  description: "Dataset con split estratificado 80/20"
}

WITH base_data AS (

  SELECT 
    *,
    RAND() AS random_val
  FROM ${ref("02_Obt_Cotizaciones")}

),

stratified AS (

  SELECT 
    *,
    NTILE(5) OVER(
      PARTITION BY COMPRO 
      ORDER BY random_val
    ) AS fold
  FROM base_data

)

SELECT 
  * EXCEPT(random_val, fold),

  IF(fold = 1, TRUE, FALSE) AS is_test

FROM stratified