config {
  type: "table",
  database: "amrl-data-prd",
  schema: "WKS_COTIZACIONES_ML",
  name: "03_Obt_Cotizaciones_split"
}

/*
TRUE  -> TEST  (2025-2026)
FALSE -> TRAIN (2021-2024)
*/

SELECT
    *,

    CASE
        WHEN ANIO_COTIZACION IN (2025, 2026)
        THEN TRUE

        ELSE FALSE
    END AS IS_TEST

FROM ${ref("02_Obt_Cotizaciones")}