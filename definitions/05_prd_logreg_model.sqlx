config {
  type: "incremental",
  schema: "WKS_COTIZACIONES_ML",
  name: "05_prd_logreg_model",
  uniqueKey: [
    "BK_NUMERO_OP",
    "IDENTIFICACION_COMPRADOR1",
    "MACROCONSOLIDADOR"
  ]
}

SELECT

    CURRENT_TIMESTAMP() AS FECHA_SCORING,
    P.*

FROM ML.PREDICT(

    MODEL `amrl-data-prd.WKS_COTIZACIONES_ML.05_logreg_model_cotizaciones_v8`,

    (

        SELECT
            *

        FROM ${ref("04_Obt_Cotizaciones_incremental")}

        ${when(incremental(),
            `WHERE CONCAT(
                    CAST(BK_NUMERO_OP AS STRING),
                    IDENTIFICACION_COMPRADOR1,
                    MACROCONSOLIDADOR
                  ) NOT IN (

                SELECT CONCAT(
                           CAST(BK_NUMERO_OP AS STRING),
                           IDENTIFICACION_COMPRADOR1,
                           MACROCONSOLIDADOR
                       )

                FROM ${self()}
            )
        `
        )}

    )

) AS P